{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "paths": {
      "@/*": ["./src/*"],
      "@beepd/ui": ["../../packages/ui/src"],
      "@beepd/api-client": ["../../packages/api-client/src"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules"]
}
