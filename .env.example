# Beepd Environment Variables
# Copy this file to .env and fill in real values
# NEVER commit .env files to git!

# =============================================================================
# API URLs (not secret - can be committed)
# =============================================================================

# Local development
PUBLIC_API_URL=http://localhost:8787
PUBLIC_APP_URL=http://localhost:4321

# Preview environment (beepd.tech for staging/dev)
# PREVIEW_API_URL=https://api-preview.beepd.tech
# PREVIEW_APP_URL=https://preview.beepd.tech

# Production (beepd.app for users)
# PROD_API_URL=https://api.beepd.app
# PROD_APP_URL=https://beepd.app

# =============================================================================
# Authentication (SECRET - set via wrangler secret or GitHub Secrets)
# =============================================================================

# JWT signing secret - generate with: openssl rand -base64 32
JWT_SECRET=replace-with-generated-secret

# =============================================================================
# Cloudflare (SECRET - set in GitHub Secrets for CI/CD)
# =============================================================================

# API token with Workers/Pages/D1 permissions
# Create at: https://dash.cloudflare.com/profile/api-tokens
CLOUDFLARE_API_TOKEN=your-api-token-here

# Account ID - found in Cloudflare Dashboard > Overview (right sidebar)
CLOUDFLARE_ACCOUNT_ID=your-account-id-here

# =============================================================================
# Mobile / Expo (SECRET - set in GitHub Secrets for CI/CD)
# =============================================================================

# EAS Build token
# Create at: https://expo.dev/accounts/[username]/settings/access-tokens
EXPO_TOKEN=your-expo-token-here

# =============================================================================
# Subscriptions (SECRET - set in .env and GitHub Secrets)
# =============================================================================

# RevenueCat API key
# Get from: https://app.revenuecat.com/settings/api-keys
REVENUECAT_API_KEY=your-revenuecat-key-here

# Stripe (optional, RevenueCat handles most payments)
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# =============================================================================
# Feature Flags (not secret)
# =============================================================================

# Enable simulated location for demo mode
ENABLE_DEMO_MODE=true

# Environment identifier
ENVIRONMENT=development
